<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Official website for IPDCEC 2026 - International Plant Design Chemical Engineering Competition." />
  <title>IPDCEC 2026 | International Plant Design Chemical Engineering Competition</title>

  <style>
    :root {
      --navy: #031b34;
      --navy-2: #062b4f;
      --green: #66bb35;
      --green-dark: #2f8f2f;
      --blue: #0c4f91;
      --white: #ffffff;
      --soft: #f4f8fc;
      --text: #08213c;
      --muted: #5d6e82;
      --border: #dce7f1;
      --shadow: 0 18px 45px rgba(3, 27, 52, 0.14);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background: var(--soft);
      color: var(--text);
      line-height: 1.65;
    }

    a { text-decoration: none; }
    .container { width: min(1180px, 90%); margin: auto; }

    .topbar {
      background: var(--navy);
      color: white;
      font-size: 13px;
      padding: 10px 0;
    }

    .topbar-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .social-icons {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .icon-link {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 900;
      font-size: 14px;
      transition: 0.2s ease;
      border: 1px solid rgba(255,255,255,0.22);
    }

    .icon-link:hover { transform: translateY(-2px); }
    .linkedin { background: #0a66c2; }
    .youtube { background: #ff0000; }
    .instagram { background: linear-gradient(135deg, #833ab4, #fd1d1d, #fcb045); }
    .tiktok { background: #111111; }

    nav {
      background: white;
      box-shadow: 0 8px 25px rgba(3, 27, 52, 0.08);
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .nav-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 0;
      gap: 20px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 310px;
    }

    .brand-logo {
      width: 72px;
      height: 72px;
      object-fit: contain;
      flex: 0 0 auto;
    }

    .brand-title strong {
      display: block;
      color: var(--navy);
      font-size: 27px;
      line-height: 1.05;
      font-weight: 900;
      letter-spacing: -0.6px;
    }

    .brand-title span {
      display: block;
      color: var(--text);
      font-size: 13px;
      max-width: 310px;
      line-height: 1.35;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav-links a {
      color: var(--navy);
      font-size: 13px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .nav-links a:hover { color: var(--green-dark); }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 14px 24px;
      border-radius: 12px;
      font-weight: 900;
      transition: 0.2s ease;
      border: none;
    }

    .btn:hover { transform: translateY(-2px); }

    .btn-green {
      background: linear-gradient(135deg, var(--green), var(--green-dark));
      color: white !important;
      box-shadow: 0 12px 24px rgba(80, 175, 50, 0.3);
    }

    .btn-outline {
      color: white;
      border: 2px solid rgba(255,255,255,0.7);
    }

    .hero {
      position: relative;
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(3, 27, 52, 0.98) 0%, rgba(3, 27, 52, 0.88) 52%, rgba(3, 27, 52, 0.68) 100%),
        radial-gradient(circle at 80% 50%, rgba(102, 187, 53, 0.25), transparent 28%),
        linear-gradient(135deg, #0b2442, #062b4f);
      color: white;
      min-height: 650px;
    }

    .hero::after {
      content: "";
      position: absolute;
      right: -120px;
      top: 40px;
      width: 520px;
      height: 520px;
      border: 26px solid rgba(102, 187, 53, 0.75);
      border-left-color: rgba(12, 79, 145, 0.85);
      border-bottom-color: rgba(12, 79, 145, 0.65);
      border-radius: 50%;
      opacity: 0.8;
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 30px;
      align-items: center;
      padding: 78px 0 110px;
    }

    .hero-kicker {
      color: var(--green);
      font-size: 28px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6px;
    }

    .hero h1 {
      font-size: clamp(44px, 6.5vw, 82px);
      line-height: 0.98;
      letter-spacing: -2px;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .hero h1 span { color: var(--green); display: block; }

    .hero p {
      font-size: 22px;
      color: #e9f4ff;
      max-width: 660px;
      margin-bottom: 30px;
    }

    .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }

    .mascot-wrap {
      position: relative;
      min-height: 430px;
      display: flex;
      align-items: flex-end;
      justify-content: center;
    }

    .mascot-wrap img {
      width: min(420px, 100%);
      max-height: 520px;
      object-fit: contain;
      filter: drop-shadow(0 30px 35px rgba(0,0,0,0.42));
      position: relative;
      z-index: 3;
    }

    .info-bar { position: relative; z-index: 4; margin-top: -80px; }

    .info-grid {
      background: linear-gradient(135deg, #042544, #06345f);
      border: 1px solid rgba(66, 174, 255, 0.45);
      border-radius: 24px;
      box-shadow: var(--shadow);
      color: white;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      overflow: hidden;
    }

    .info-item {
      padding: 24px;
      border-right: 1px solid rgba(255,255,255,0.16);
    }

    .info-item:last-child { border-right: none; }
    .info-icon { color: var(--green); font-size: 30px; margin-bottom: 10px; }

    .info-item h3 {
      font-size: 16px;
      line-height: 1.25;
      margin-bottom: 6px;
      text-transform: uppercase;
    }

    .info-item p { font-size: 13px; color: #d7e9f8; }

    section { padding: 78px 0; }

    .section-header { max-width: 820px; margin-bottom: 34px; }

    .eyebrow {
      color: var(--green-dark);
      font-weight: 900;
      text-transform: uppercase;
      font-size: 14px;
      letter-spacing: 1.2px;
      margin-bottom: 8px;
    }

    .section-title {
      color: var(--navy);
      font-size: clamp(30px, 4vw, 46px);
      line-height: 1.12;
      letter-spacing: -1px;
      margin-bottom: 14px;
    }

    .section-header p { color: var(--muted); font-size: 18px; }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 22px;
    }

    .card {
      background: white;
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 28px;
      box-shadow: var(--shadow);
    }

    .card h3 { color: var(--navy); margin-bottom: 10px; font-size: 21px; }
    .card p, .card li { color: var(--muted); }
    .card ul { padding-left: 18px; margin-top: 10px; }
    .highlight { background: white; }

    .theme-quote {
      background: radial-gradient(circle at right, rgba(102,187,53,0.16), transparent 35%), linear-gradient(135deg, #f8fbff, #ffffff);
      border-radius: 26px;
      padding: 34px;
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
      margin-bottom: 26px;
    }

    .theme-quote h3 {
      font-size: clamp(24px, 3vw, 34px);
      color: var(--navy);
      font-style: italic;
      line-height: 1.35;
    }

    .theme-card { border-top: 6px solid var(--green); }

    .timeline { display: grid; gap: 18px; }

    .timeline-item {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 24px;
      background: white;
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(3,27,52,0.08);
    }

    .date { color: var(--green-dark); font-weight: 900; }
    .timeline-item h3 { color: var(--navy); margin-bottom: 4px; }

    .guidebook-box {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 28px;
      align-items: center;
      background: linear-gradient(135deg, var(--navy), var(--navy-2));
      color: white;
      border-radius: 34px;
      padding: 44px;
      box-shadow: var(--shadow);
      overflow: hidden;
      position: relative;
    }

    .guidebook-box::after {
      content: "";
      position: absolute;
      right: -70px;
      bottom: -80px;
      width: 260px;
      height: 260px;
      background: rgba(102,187,53,0.22);
      border-radius: 50%;
    }

    .guidebook-box h2 { font-size: clamp(28px, 4vw, 44px); line-height: 1.12; margin-bottom: 14px; }
    .guidebook-box p { color: #e7f4ff; margin-bottom: 22px; }

    .guide-card {
      position: relative;
      z-index: 1;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.22);
      border-radius: 26px;
      padding: 28px;
    }

    .contact-grid, .social-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(245px, 1fr));
      gap: 18px;
    }

    .contact-card, .social-card {
      background: white;
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 12px 32px rgba(3,27,52,0.08);
    }

    .contact-card h3, .social-card h3 { color: var(--navy); margin-bottom: 8px; }
    .wa-link, .social-link { display: inline-block; margin-top: 10px; color: var(--green-dark); font-weight: 900; }

    .payment-card strong {
      display: block;
      font-size: 22px;
      color: var(--navy);
      margin-bottom: 6px;
    }

    .payment-number {
      font-size: 24px;
      font-weight: 900;
      color: var(--green-dark);
      letter-spacing: 0.5px;
    }

    .cta {
      margin: 34px auto 82px;
      padding: 62px 40px;
      border-radius: 34px;
      background: radial-gradient(circle at top right, rgba(102,187,53,0.25), transparent 30%), linear-gradient(135deg, var(--navy), var(--navy-2));
      color: white;
      text-align: center;
      box-shadow: var(--shadow);
    }

    .cta h2 { font-size: clamp(30px, 4vw, 48px); line-height: 1.14; margin-bottom: 12px; }
    .cta p { max-width: 760px; margin: 0 auto 26px; color: #e7f4ff; font-size: 18px; }

    footer { background: var(--navy); color: #d7e9f8; padding: 34px 0; }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
      font-size: 14px;
    }

    footer strong { color: white; }

    @media (max-width: 980px) {
      .hero-inner { grid-template-columns: 1fr; padding-bottom: 135px; }
      .mascot-wrap { min-height: auto; }
      .mascot-wrap img { width: min(340px, 78%); }
      .info-grid { grid-template-columns: 1fr 1fr; }
      .guidebook-box { grid-template-columns: 1fr; }
    }

    @media (max-width: 760px) {
      .topbar-inner, .nav-inner { align-items: flex-start; flex-direction: column; }
      .nav-links { justify-content: flex-start; gap: 14px; }
      .brand-logo { width: 58px; height: 58px; }
      .brand-title strong { font-size: 22px; }
      .info-grid { grid-template-columns: 1fr; }
      .info-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.16); }
      .timeline-item { grid-template-columns: 1fr; gap: 6px; }
    }
  </style>
</head>

<body>
  <div class="topbar">
    <div class="container topbar-inner">
      <div>International Plant Design Chemical Engineering Competition</div>
      <div>Universitas Malikussaleh, Aceh, Indonesia</div>
      <div class="social-icons">
        <a class="icon-link linkedin" href="https://www.linkedin.com/in/international-plant-design-chemical-engineering-competition-ipdcec-a4b814405" target="_blank" aria-label="LinkedIn">in</a>
        <a class="icon-link youtube" href="https://youtube.com/@ipdcec2026?si=FHp4n-Rl6VyOKPO9" target="_blank" aria-label="YouTube">▶</a>
        <a class="icon-link instagram" href="https://www.instagram.com/ipdcec2026" target="_blank" aria-label="Instagram">◎</a>
        <a class="icon-link tiktok" href="https://www.tiktok.com/@ipdcec2026?_r=1&_t=ZS-95pw8U9oQQU" target="_blank" aria-label="TikTok">♪</a>
      </div>
    </div>
  </div>

  <nav>
    <div class="container nav-inner">
      <div class="brand">
        <img class="brand-logo" src="ipdcec-logo.png" alt="IPDCEC Logo" />
        <div class="brand-title">
          <strong>IPDCEC 2026</strong>
          <span>International Plant Design Chemical Engineering Competition</span>
        </div>
      </div>
      <div class="nav-links">
        <a href="#about">Home</a>
        <a href="#about">About</a>
        <a href="#theme">Theme</a>
        <a href="#timeline">Timeline</a>
        <a href="#guidebook">Guidebook</a>
        <a href="#payment">Payment</a>
        <a href="#contact">Contact</a>
        <a class="btn btn-green" href="https://docs.google.com/forms/d/e/1FAIpQLSfUYEMS-28M-9XcN0zA7j4W05MKoiFdyN7_Uy1xzEUrM7i6Rg/viewform" target="_blank">Register Now →</a>
      </div>
    </div>
  </nav>

  <header class="hero">
    <div class="container hero-inner">
      <div>
        <div class="hero-kicker">International</div>
        <h1>Plant Design Chemical Engineering <span>Competition 2026</span></h1>
        <p>Designing sustainable chemical plants for a better global future.</p>
        <div class="hero-actions">
          <a class="btn btn-green" href="https://docs.google.com/forms/d/e/1FAIpQLSfUYEMS-28M-9XcN0zA7j4W05MKoiFdyN7_Uy1xzEUrM7i6Rg/viewform" target="_blank">Register Now →</a>
          <a class="btn btn-outline" href="https://drive.google.com/file/d/1hbAAebrIHGOceAb5zoJW6p10Npcm20Qv/view?usp=sharing" target="_blank">Download Guidebook</a>
        </div>
      </div>

      <div class="mascot-wrap">
        <img src="mascot-ipdcec.png" alt="IPDCEC 2026 Mascot" />
      </div>
    </div>
  </header>

  <div class="container info-bar">
    <div class="info-grid">
      <div class="info-item"><div class="info-icon">⌂</div><h3>Offline Competition</h3><p>Universitas Malikussaleh, Aceh, Indonesia</p></div>
      <div class="info-item"><div class="info-icon">◎</div><h3>International Event</h3><p>Open for Chemical Engineering students worldwide</p></div>
      <div class="info-item"><div class="info-icon">👥</div><h3>Team up to 3 Members</h3><p>+ 1 lecturer supervisor from the same institution</p></div>
      <div class="info-item"><div class="info-icon">▣</div><h3>Simulation Required</h3><p>Aspen HYSYS or Aspen Plus</p></div>
    </div>
  </div>

  <section id="about">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">About IPDCEC</div>
        <h2 class="section-title">A global platform for future chemical engineers</h2>
        <p>IPDCEC is an international chemical plant design competition organized by the Chemical Engineering Department, Faculty of Engineering, Universitas Malikussaleh. This competition challenges students to design comprehensive, safe, efficient, and sustainable chemical plants.</p>
      </div>
      <div class="grid">
        <div class="card"><h3>Global Participation</h3><p>Open to active Chemical Engineering students from universities around the world.</p></div>
        <div class="card"><h3>Innovative Solutions</h3><p>Encouraging process innovation, engineering creativity, and practical industrial design.</p></div>
        <div class="card"><h3>Sustainable Future</h3><p>Focused on efficient process design, energy optimization, safety, economics, and environmental responsibility.</p></div>
      </div>
    </div>
  </section>

  <section id="theme" class="highlight">
    <div class="container">
      <div class="section-header"><div class="eyebrow">Theme & Subtheme</div><h2 class="section-title">Competition Theme</h2></div>
      <div class="theme-quote"><h3>“Perancangan Pabrik Kimia Berbasis Industri untuk Masa Depan Global yang Berkelanjutan”</h3></div>
      <div class="grid">
        <div class="card theme-card"><h3>01. Cleaner Energy from Natural Gas</h3><p>Utilization of natural gas as a cleaner energy source through process optimization and emission reduction.</p><ul><li>Hydrogen (H2)</li><li>DME</li><li>Methanol</li><li>SNG</li><li>GTL fuels</li></ul></div>
        <div class="card theme-card"><h3>02. Value-Added Chemical Products</h3><p>Downstream processing of natural gas into value-added chemical products for sustainable and eco-friendly industry.</p><ul><li>Ammonia and Urea</li><li>Olefin and Polymers</li><li>Formaldehyde</li><li>Acetic Acid</li><li>Petrochemical derivatives</li></ul></div>
      </div>
    </div>
  </section>

  <section id="timeline">
    <div class="container">
      <div class="section-header"><div class="eyebrow">Timeline</div><h2 class="section-title">Competition Schedule</h2><p>Please submit all documents before the official deadline and regularly check official announcements.</p></div>
      <div class="timeline">
        <div class="timeline-item"><div class="date">1 – 14 May 2026</div><div><h3>Registration & Extended Abstract Submission</h3><p>Team registration and extended abstract submission period.</p></div></div>
        <div class="timeline-item"><div class="date">21 May 2026</div><div><h3>Semifinalist Announcement</h3><p>The best 20 teams from the Extended Abstract stage will be announced.</p></div></div>
        <div class="timeline-item"><div class="date">22 May – 15 June 2026</div><div><h3>Full Paper Submission</h3><p>Selected teams submit their complete plant design report.</p></div></div>
        <div class="timeline-item"><div class="date">25 June 2026</div><div><h3>Finalist Announcement</h3><p>The top 6 teams will proceed to the final presentation stage.</p></div></div>
        <div class="timeline-item"><div class="date">5 July 2026</div><div><h3>Final Presentation</h3><p>Finalists present their plant design offline at Universitas Malikussaleh.</p></div></div>
        <div class="timeline-item"><div class="date">6 – 7 July 2026</div><div><h3>Field Trip & Awarding</h3><p>Field trip and awarding ceremony for IPDCEC 2026 participants.</p></div></div>
      </div>
    </div>
  </section>

  <section id="guidebook" class="highlight">
    <div class="container">
      <div class="guidebook-box">
        <div><h2>Download the Official Guidebook</h2><p>Read the complete guidebook before registering. It contains the official rules, timeline, registration requirements, payment information, and competition stages.</p><div class="hero-actions"><a class="btn btn-green" href="https://drive.google.com/file/d/1hbAAebrIHGOceAb5zoJW6p10Npcm20Qv/view?usp=sharing" target="_blank">Download Guidebook</a><a class="btn btn-outline" href="https://docs.google.com/forms/d/e/1FAIpQLSfUYEMS-28M-9XcN0zA7j4W05MKoiFdyN7_Uy1xzEUrM7i6Rg/viewform" target="_blank">Register Now</a></div></div>
        <div class="guide-card"><h3>Guidebook File</h3><p>The official guidebook is available through Google Drive. Please read all requirements carefully before registration.</p></div>
      </div>
    </div>
  </section>

  <section id="payment">
    <div class="container">
      <div class="section-header"><div class="eyebrow">Payment Information</div><h2 class="section-title">Registration Payment</h2><p>Please complete payment according to the competition stage and upload proof of payment through the registration form.</p></div>
      <div class="grid">
        <div class="card payment-card"><strong>BSI Bank Transfer</strong><p>Account Number</p><div class="payment-number">xxx</div></div>
        <div class="card payment-card"><strong>PayPal</strong><p>PayPal Account</p><div class="payment-number">xxx</div></div>
        <div class="card"><h3>Registration Fee</h3><p>Extended Abstract: Indonesia Rp50.000 / International 5 USD.<br>Full Paper: Indonesia Rp250.000 / International 18 USD.</p></div>
      </div>
    </div>
  </section>

  <section id="contact" class="highlight">
    <div class="container">
      <div class="section-header"><div class="eyebrow">Contact Person</div><h2 class="section-title">Need Help with Registration?</h2><p>For registration and competition inquiries, please contact the official committee representatives below.</p></div>
      <div class="contact-grid">
        <div class="contact-card"><h3>Novitasari</h3><p>Contact Person</p><a class="wa-link" href="https://wa.me/6283168532383" target="_blank">WhatsApp: +62 831-6853-2383</a></div>
        <div class="contact-card"><h3>Ayu Adinda P. Ginting</h3><p>Contact Person</p><a class="wa-link" href="https://wa.me/6282274680923" target="_blank">WhatsApp: +62 822-7468-0923</a></div>
        <div class="contact-card"><h3>Syaida</h3><p>Contact Person</p><a class="wa-link" href="https://wa.me/6281267055711" target="_blank">WhatsApp: +62 812-6705-5711</a></div>
      </div>
    </div>
  </section>

  <section id="social">
    <div class="container">
      <div class="section-header"><div class="eyebrow">Follow Us</div><h2 class="section-title">Official IPDCEC Social Media</h2></div>
      <div class="social-grid">
        <div class="social-card"><div class="icon-link linkedin">in</div><h3>LinkedIn</h3><p>International Plant Design Chemical Engineering Competition IPDCEC</p><a class="social-link" href="https://www.linkedin.com/in/international-plant-design-chemical-engineering-competition-ipdcec-a4b814405" target="_blank">Open LinkedIn</a></div>
        <div class="social-card"><div class="icon-link youtube">▶</div><h3>YouTube</h3><p>@ipdcec2026</p><a class="social-link" href="https://youtube.com/@ipdcec2026?si=FHp4n-Rl6VyOKPO9" target="_blank">Open YouTube</a></div>
